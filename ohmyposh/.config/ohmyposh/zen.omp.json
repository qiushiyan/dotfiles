{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palettes": {
    "template": "{{ if .Env.TERMINAL_THEME }}{{ .Env.TERMINAL_THEME }}{{ else }}flexoki_light{{ end }}",
    "list": {
      "flexoki_light": {
        "os": "#878580",
        "closer": "p:os",
        "pink": "#a02f6f",
        "lavender": "#a02f6f",
        "blue":  "#205ea6",
        "green": "#66800b",
        "peach": "#ad8301",
        "red": "#af3029"
      },
      "catppuccin_mocha": {
        "os": "#ACB0BE",
        "closer": "p:os",
        "pink": "#F5C2E7",
        "lavender": "#B4BEFE",
        "blue":  "#89B4FA",
        "green": "#A6E3A1",
        "peach": "#FAB387",
        "red": "#F38BA8"
      },
      "tailwind_light": {
        "os": "#62748e",
        "closer": "p:os",
        "pink": "#9810fa",
        "lavender": "#9810fa",
        "blue":  "#1447e6",
        "green": "#009966",
        "peach": "#e17100",
        "red": "#c70036"
      },
      "tokyo_night_moon": {
        "os": "#828bb8",
        "closer": "p:os",
        "pink": "#fca7ea",
        "lavender": "#c8d3f5",
        "blue":  "#86e1fc",
        "green": "#c3e88d",
        "peach": "#ff966c",
        "red": "#ff757f"
      },
      "gruvbox_dark": {
        "os": "#928374",
        "closer": "p:os",
        "pink": "#d3869b",
        "lavender": "#ebdbb2",
        "blue":  "#8ec07c",
        "green": "#b8bb26",
        "peach": "#fe8019",
        "red": "#fb4934"
      }
    }
  },
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "p:blue",
          "options": {
            "home_icon": "~",
            "style": "full"
          },
          "style": "plain",
          "template": "{{ .Path }}",
          "type": "path"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "foreground": "p:lavender",
          "options": {
            "branch_icon": "\ue725 ",
            "cherry_pick_icon": "\ue29b ",
            "commit_icon": "\uf417 ",
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "merge_icon": "\ue727 ",
            "no_commits_icon": "\uf0c3 ",
            "rebase_icon": "\ue728 ",
            "revert_icon": "\uf0e2 ",
            "tag_icon": "\uf412 "
          },
          "template": "{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "style": "plain",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "style": "plain",
          "foreground": "p:green",
          "template": "❯",
          "type": "text"
        }
      ],
      "type": "prompt",
      "newline": true
    }
  ],
  "transient_prompt": {
    "foreground": "p:green",
    "foreground_templates": [
      "{{ if gt .Code 0 }}p:red{{ end }}"
    ],
    "template": "❯ "
  },
  "final_space": true,
  "version": 4
}
