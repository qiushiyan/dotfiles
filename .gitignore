# Stow-package runtime state — written by the apps themselves, not
# config worth versioning. Each entry is intentionally specific so we
# don't accidentally hide real config files in the same directory.

# === Claude Code (claude/.claude/ — config like settings.json, skills/,
# hooks/, agents/, commands/, memory/, CLAUDE.md, keybindings.json
# stays tracked) ===
claude/.claude/.last-*
claude/.claude/backups/
claude/.claude/cache/
claude/.claude/downloads/
claude/.claude/file-history/
claude/.claude/history.jsonl
claude/.claude/image-cache/
claude/.claude/mcp-needs-auth-cache.json
claude/.claude/paste-cache/
claude/.claude/plans/
claude/.claude/plugins/
claude/.claude/projects/
claude/.claude/session-env/
claude/.claude/sessions/
claude/.claude/shell-snapshots/
claude/.claude/tasks/
claude/.claude/telemetry/
# Packaged skill exports (zip artifacts) — the real skills live in skills/
claude/.claude/*.skill

# === Codex CLI (codex/.codex/) ===
# ~/.codex is a single folded stow symlink to this dir, so Codex writes
# ALL of its runtime state here: sqlite DBs (logs are ~160 MB), session
# transcripts, caches, plugins, auth.json, pasted-text attachments, etc.
# This repo is PUBLIC, so ignore everything by default and allow-list only
# real config — that way new runtime files Codex invents can't sneak in.
codex/.codex/*
!codex/.codex/config.toml
!codex/.codex/AGENTS.md
!codex/.codex/prompts/
!codex/.codex/skills/
# ...but skip the bundled system skills (Codex reinstalls these).
codex/.codex/skills/.system/

# === Neovim scratch sandbox (nvim/.config/nvim/sandbox/) ===
# Throwaway playground files for testing LSP/formatters/treesitter across
# filetypes — not config. Kept on disk locally, out of the repo.
nvim/.config/nvim/sandbox/

# === SSH (ssh/.ssh/config) ===
# config is a per-file stow symlink; untracked here because on a PUBLIC
# repo it leaks work usernames/orgs and host logins. The live
# ~/.ssh/config keeps working via the symlink.
ssh/.ssh/config

# === Ghostty (auto/ is auto-written theme include; the real config
# lives in ghostty/.config/ghostty/config) ===
ghostty/.config/ghostty/auto/

# === TabType usage history (runtime telemetry) ===
tabtype/.config/tabtype/history.json

# === Karabiner auto-rotated backups ===
karabiner/.config/karabiner/automatic_backups/

# === Tmux plugins (managed by tpm; bootstrap re-clones them) ===
tmux/.config/tmux/plugins/

# === Zed prompt library (binary LMDB; rsync from old Mac if needed) ===
zed/.config/zed/prompts/

# === Misc tool droppings ===
.python-version
.DS_Store
