# Stow-package runtime state — written by the apps themselves, not
# config worth versioning. Each entry is intentionally specific so we
# don't accidentally hide real config files in the same directory.

# === Claude Code (claude/.claude/) ===
# ~/.claude is a real directory; only config is symlinked in from this
# package (settings.json, hooks/, agents/, commands/, rules/, skills/,
# CLAUDE.md), so Claude's runtime state (history, sessions, projects,
# telemetry, plugins, caches, …) lives in the real ~/.claude and never
# reaches this repo. This allow-list is defense-in-depth for a PUBLIC repo:
# ignore everything under the package, then re-include only real config —
# so any runtime file that ever lands here can't be committed by accident.
claude/.claude/*
!claude/.claude/CLAUDE.md
!claude/.claude/settings.json
!claude/.claude/agents/
!claude/.claude/commands/
!claude/.claude/hooks/
!claude/.claude/rules/
!claude/.claude/skills/
# ...but never the packaged skill exports (zip artifacts).
claude/.claude/skills/**/*.skill

# === Codex CLI (codex/.codex/) ===
# ~/.codex is a real directory (like ~/.claude); only config is symlinked in
# from here, so Codex's runtime state — sqlite DBs (logs ~160 MB), session
# transcripts, caches, plugins, the auth.json SECRET, attachments, etc. —
# lives in the real ~/.codex and never reaches this repo. This allow-list is
# defense-in-depth for a PUBLIC repo: ignore everything, re-include only real
# config, so any runtime file Codex invents can't be committed by accident.
codex/.codex/*
!codex/.codex/config.toml
!codex/.codex/AGENTS.md
!codex/.codex/prompts/
!codex/.codex/skills/
# ...but skip the bundled system skills (Codex reinstalls these).
codex/.codex/skills/.system/

# === Neovim scratch sandbox (nvim/.config/nvim/sandbox/) ===
# Throwaway playground files for testing LSP/formatters/treesitter across
# filetypes — not config. Kept on disk locally, out of the repo.
nvim/.config/nvim/sandbox/

# === SSH (ssh/.ssh/config) ===
# config is a per-file stow symlink; untracked here because on a PUBLIC
# repo it leaks work usernames/orgs and host logins. The live
# ~/.ssh/config keeps working via the symlink.
ssh/.ssh/config

# === Ghostty (auto/ is auto-written theme include; the real config
# lives in ghostty/.config/ghostty/config) ===
ghostty/.config/ghostty/auto/

# === TabType usage history (runtime telemetry) ===
tabtype/.config/tabtype/history.json

# === Karabiner auto-rotated backups ===
karabiner/.config/karabiner/automatic_backups/

# === Tmux plugins (managed by tpm; bootstrap re-clones them) ===
tmux/.config/tmux/plugins/

# === Zed prompt library (binary LMDB; rsync from old Mac if needed) ===
zed/.config/zed/prompts/

# === Misc tool droppings ===
.python-version
.DS_Store
