# vim: ft=conf
# The active theme is set by the switcher-managed include at the BOTTOM of this
# file (theme-set regenerates ~/.config/ghostty/auto/theme.ghostty). Do not set
# `theme` here — leaving it out makes the include the single source of truth.
# macOS has no external config reload, so after switching press ⌘⇧, to reload.
# theme = Catppuccin Mocha
background-opacity = 0.85
background-blur-radius = 25
# theme = TokyoNight
# font-family = JetBrainsMono Nerd Font
# font-family = DankMono Nerd Font Mono


font-family = Berkeley Mono
font-size = 22
font-thicken = true
adjust-cell-width = -2%
adjust-cell-height = 15%

# font-size = 24
# font-family = IosevkaTerm Nerd Font
# font-thicken = true
# adjust-cell-height = 20%
# adjust-cell-width = -2%


# font-codepoint-map = U+23FB-U+23FE,U+2665,U+26A1,U+2B58,U+E000-U+E00A,U+E0A0-U+E0A3,U+E0B0-U+E0D4,U+E200-U+E2A9,U+E300-U+E3E3,U+E5FA-U+E6AA,U+E700-U+E7C5,U+EA60-U+EBEB,U+F000-U+F2E0,U+F300-U+F32F,U+F400-U+F4A9,U+F500-U+F8FF,U+F0001-U+F1AF0=Symbols Nerd Font Mono
font-codepoint-map = U+4E00-U+9FFF,U+3400-U+4DBF=Maple Mono NF CN
clipboard-paste-protection = false

copy-on-select = true

cursor-style = block
cursor-style-blink = false
cursor-color = cell-foreground
cursor-text = cell-background
shell-integration-features = no-cursor

mouse-hide-while-typing = true
mouse-scroll-multiplier = 2
macos-titlebar-style = hidden

window-width = 130
window-height = 27
window-padding-balance = true
window-padding-x = 4
window-padding-y = 4
window-save-state = always
window-colorspace = "display-p3"

# custom-shader = shaders/cursor_frozen.glsl


keybind = shift+ctrl+r=reload_config
keybind = performable:ctrl+c=copy_to_clipboard
# sesh session picker (sends prefix T to tmux)
keybind = ctrl+shift+p=text:\x01T
keybind = ctrl+`=toggle_quick_terminal


# initial-command = "~/.config/dev-itell.sh"
wait-after-command = true
quit-after-last-window-closed=false

keybind = shift+enter=text:\n
keybind = ctrl+shift+up=scroll_page_up
keybind = ctrl+shift+down=scroll_page_down
keybind = shift+up=scroll_page_lines:-10
keybind = shift+down=scroll_page_lines:10

keybind = ctrl+shift+v=new_split:right

keybind = ctrl+shift+h=new_split:down

# Navigate between panes (vim-style)
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:bottom
keybind = ctrl+shift+k=goto_split:top
keybind = ctrl+shift+l=goto_split:right


# -- theme (switcher-managed) --------------------------------------------------
# theme-set regenerates this gitignored include on every switch (full rewrite =
# no stale keys). Kept LAST so any per-theme field a theme defines there (e.g. a
# theme-specific background-opacity) overrides the base values above. `?` makes
# it optional, so a fresh install with no include yet still loads cleanly.
config-file = ?auto/theme.ghostty
